# LLM gateway (OpenAI-compatible; Vercel AI Gateway by default)
FINCH_GATEWAY_API_KEY=
FINCH_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
FINCH_EXTRACTION_MODEL=anthropic/claude-haiku-4.5
FINCH_ADJUDICATION_MODEL=anthropic/claude-sonnet-5

# Embeddings (legal-domain)
FINCH_VOYAGE_API_KEY=
FINCH_EMBEDDING_MODEL=voyage-law-2

# Vector store (empty QDRANT_URL = in-memory, fine for local dev)
FINCH_QDRANT_URL=
FINCH_QDRANT_API_KEY=

# Escalation web search
FINCH_TAVILY_API_KEY=

# Case law corpus
FINCH_COURTLISTENER_TOKEN=

# Persistence (empty = in-memory checkpointer; set to a Postgres URL in production)
FINCH_DATABASE_URL=

# Allowed browser origin for CORS (the deployed frontend URL; * for local dev)
FINCH_FRONTEND_ORIGIN=*

# Tracing (optional; loaded into the process env, read by the tracing SDK)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finch
